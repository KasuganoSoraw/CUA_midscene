{
  "name": "cua_midscene",
  "version": "1.0.0",
  "description": "Midscene computer-use experiments for local desktop automation.",
  "type": "module",
  "scripts": {
    "check": "tsx src/check-env.ts",
    "flow:convert": "tsx src/flow/conversion/convert-showui-trace.ts",
    "project:list": "tsx src/flow/task/cli.ts project:list",
    "flow:validate": "tsx src/flow/task/cli.ts flow:validate",
    "flow:inspect": "tsx src/flow/task/cli.ts flow:inspect",
    "flow:run": "tsx src/flow/execution/run-midscene-flow.ts",
    "calibration:validate": "tsx src/flow/task/cli.ts calibration:validate",
    "calibration:apply": "tsx src/flow/task/cli.ts calibration:apply",
    "test:task-resolver": "tsx tests/flow/task/cli-args.test.ts && tsx tests/flow/task/resolver.test.ts && tsx tests/flow/task/calibration.test.ts",
    "test:input-locate": "tsx tests/flow/conversion/input-locate-prompt.test.ts",
    "test:keyboard-type": "tsx tests/flow/execution/keyboard-type-action.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@midscene/computer": "^1.10.0",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@types/node": "^18.19.68"
  }
}
