# Copy to .env.local and fill in real values. .env.local is intentionally ignored by git.
MIDSCENE_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
MIDSCENE_MODEL_NAME=minimax-m3
MIDSCENE_MODEL_API_KEY=replace-me

# Required for Midscene computer use. Choose a value supported by Midscene.
# For Volcengine Ark visual models this is often doubao-vision. minimax-m3 may not be vision-capable.
MIDSCENE_MODEL_FAMILY=doubao-vision

MIDSCENE_PREFERRED_LANGUAGE=zh-CN
MIDSCENE_REPLANNING_CYCLE_LIMIT=10
MIDSCENE_RUN_DIR=midscene_run

# Optional: override the query used by npm run google.
GOOGLE_SEARCH_QUERY=GUI agent
