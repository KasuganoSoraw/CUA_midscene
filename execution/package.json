{
  "name": "cua-midscene",
  "version": "1.0.0",
  "description": "基于 TypeScript 与 Midscene computer use 的 CUA 任务执行器。",
  "type": "module",
  "bin": {
    "cua": "./dist/cli/main.js"
  },
  "exports": {
    ".": "./dist/cua/index.js"
  },
  "files": [
    ".env.example",
    "agents",
    "cli",
    "cua",
    "dist",
    "executors",
    "projects",
    "references",
    "review",
    "schemas",
    "README.md",
    "SKILL.md",
    "tsconfig.build.json",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=18.19.0"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:node": "tsc -p tsconfig.build.json",
    "build:web": "vite build --config review/web/vite.config.ts",
    "build": "npm run clean && npm run build:node && npm run build:web",
    "prepack": "npm run build",
    "cua": "tsx cli/main.ts",
    "check": "tsx executors/check-env.ts",
    "typecheck": "tsc --noEmit && vue-tsc --noEmit -p review/web/tsconfig.json",
    "test": "npm run typecheck && tsx --test tests/all.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@midscene/computer": "^1.10.0",
    "@midscene/core": "^1.10.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.7",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^18.19.68",
    "@vitejs/plugin-vue": "^5.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.4.1",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.12"
  }
}
