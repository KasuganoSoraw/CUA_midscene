# Copy to .env and fill in the real key. .env is intentionally ignored by git.
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
OPENAI_MODEL=minimax-m3
OPENAI_API_KEY=replace-me

# Keep true by default. Set false only for an internal endpoint whose certificate cannot be verified.
OPENAI_VERIFY_SSL=true

# Optional: tune trace generation without editing code.
ALOHA_TRACE_TEMPERATURE=0.2
